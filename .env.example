# ── Required ──────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your-discord-bot-token-here
CHANNEL_ID=123456789012345678
GITHUB_REPO_PATH=/home/user/my-dynmap-pages
GITHUB_PAGES_URL=https://yourusername.github.io/repo

# ── FTP / SFTP (required for automatic trigger-based deploys) ──────────────
FTP_HOST=your.minecraft.server.com
FTP_USER=your-ftp-username
FTP_PASS=your-ftp-password
FTP_PATH=/plugins/dynmap/web
FTP_PORT=21
# Set to "true" if your server uses SFTP (SSH file transfer) instead of FTP
USE_SFTP=false
# The message that triggers an FTP download + deploy
TRIGGER_PHRASE=Map is ready for print

# ── Optional ───────────────────────────────────────────────────────────────
GITHUB_PAT=your-github-personal-access-token
GIT_USER_NAME=Dynmap Bot
GIT_USER_EMAIL=bot@dynmap
DELETE_ZIP=false
IGNORE_DUPLICATES=false
# Port for the keep-alive health server (default 9090; change if port conflicts)
HEALTH_PORT=9090
