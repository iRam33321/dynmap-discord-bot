# ── Required ─────────────────────────────────────────────────────────────────

# Your Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your-discord-bot-token-here

# The numeric ID of the Discord channel to monitor for ZIP uploads
# Enable Developer Mode in Discord (Settings → Advanced) then right-click
# the channel and choose "Copy Channel ID"
CHANNEL_ID=123456789012345678

# Absolute path to your local clone of the GitHub Pages repository
# The bot will extract ZIP contents directly into this directory
GITHUB_REPO_PATH=/home/user/my-dynmap-pages

# The public GitHub Pages URL shown in success messages
GITHUB_PAGES_URL=https://yourusername.github.io/your-repo

# ── Optional ─────────────────────────────────────────────────────────────────

# Set to "true" to skip ZIP uploads whose SHA-256 hash matches the last
# successfully processed upload (useful to avoid re-deploying the same map
# snapshot multiple times)
IGNORE_DUPLICATES=false

# Set to "true" to delete any temporary ZIP file written to disk after
# successful deployment. The default pipeline keeps ZIPs in memory, so this
# flag is mainly relevant if you add disk-based caching in the future.
DELETE_ZIP=false

# Git commit author identity (defaults shown)
GIT_USER_NAME=Dynmap Bot
GIT_USER_EMAIL=bot@dynmap
